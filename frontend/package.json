{
  "name": "stocky-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti :3000 | xargs kill -9 2>/dev/null; next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "scan:errors": "playwright test --config=playwright.scanner.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "watch:errors": "node scripts/watch-errors.js",
    "fix:errors": "node scripts/fix-errors.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.91.3",
    "@tanstack/react-query-devtools": "^5.60.0",
    "autoprefixer": "10.4.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^15.3.8",
    "postcss": "8.4.35",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.52.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "3.4.1",
    "tailwindcss-animate": "1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^10.1.0",
    "eslint-config-next": "^16.2.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
