{
  "name": "stocky-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti :3000 | xargs kill -9 2>/dev/null; next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "scan:errors": "playwright test --config=playwright.scanner.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "watch:errors": "node scripts/watch-errors.js",
    "fix:errors": "node scripts/fix-errors.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@sentry/nextjs": "^10.45.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-query-devtools": "^5.96.1",
    "autoprefixer": "10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "postcss": "8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tailwindcss-animate": "1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.59.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9.0.0"
  }
}
