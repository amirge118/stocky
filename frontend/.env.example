# Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API — leave NEXT_PUBLIC_API_BASE_URL empty to use same-origin /api/v1 (Next rewrites).
# For local dev you can still set http://localhost:8000 to call the API directly.
# On Vercel, set BACKEND_INTERNAL_URL to your deployed FastAPI URL (required when NEXT_PUBLIC is empty).
NEXT_PUBLIC_API_BASE_URL=
BACKEND_INTERNAL_URL=

# Application Environment
# Options: development, production, staging
NEXT_PUBLIC_APP_ENV=development

# Sentry Error Tracking (optional — errors are silently ignored if unset)
# Get from: https://sentry.io → Settings → Projects → [your project] → Client Keys (DSN)
# Note: use the FRONTEND project DSN here, not the backend one
NEXT_PUBLIC_SENTRY_DSN=
