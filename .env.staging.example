# Staging Environment Variables
# Copy to backend/.env (or your deploy secrets) — app Docker stack has no db/redis services.
# Use real host URLs (managed Postgres, Upstash, etc.).

DATABASE_URL=postgresql+asyncpg://user:CHANGE_ME@your-db-host:5432/stock_insight_staging
REDIS_URL=redis://your-redis-host:6379/0
CELERY_BROKER_URL=redis://your-redis-host:6379/0
CELERY_RESULT_BACKEND=redis://your-redis-host:6379/1
SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM_KEY
CORS_ORIGINS=https://staging.yourdomain.com
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Staging / deploy (e.g. Vercel build env for the browser-facing API URL)
STAGING_CORS_ORIGINS=https://staging.yourdomain.com
STAGING_PUBLIC_API_URL=https://api.staging.yourdomain.com
