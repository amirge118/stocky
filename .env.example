# Optional root `.env` — used by docker-compose.yml for variable substitution
# (mainly NEXT_PUBLIC_* for the frontend service).
#
#   cp .env.example .env
#
# Backend secrets and DATABASE_URL / REDIS_URL live in backend/.env (see backend/.env.example).

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
