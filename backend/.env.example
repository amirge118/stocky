# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
# Format: postgresql+asyncpg://user:password@host:port/database
# When using npm run docker:infra: postgresql+asyncpg://stocky:stocky_dev@localhost:5432/stock_insight
DATABASE_URL=postgresql+asyncpg://stocky:stocky_dev@localhost:5432/stock_insight

# JWT Authentication
# Generate a secure random string for production (e.g., openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI/ML Services
# Get your API keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# CORS Configuration
# Comma-separated list of allowed origins
# Development: http://localhost:3000
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: Redis Cache (required for agents). When using npm run docker:infra: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Application Environment
# Options: development, production, staging
ENVIRONMENT=development

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Request/response payload logging (set false in production for sensitive data)
LOG_REQUEST_PAYLOAD=true
LOG_RESPONSE_PAYLOAD=true
LOG_PAYLOAD_MAX_LENGTH=2000
