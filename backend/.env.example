# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
# Format: postgresql+asyncpg://user:password@host:port/database
#
# Local Postgres (optional: brew, cloud, or `docker run` — see docs/setup/DOCKER.md):
#   postgresql+asyncpg://stocky:stocky_dev@localhost:5432/stock_insight
#
# App containers (docker compose up) use this URL as-is. For DB on your host machine
# from inside a container, use host.docker.internal instead of localhost (macOS/Windows),
# or your cloud provider URL (Supabase, RDS, etc.).
#
# Supabase — from Docker Desktop, direct host db.*.supabase.co is often IPv6-only (connection fails
# with Errno 99). Use Session or Transaction pooler from Dashboard → Settings → Database instead:
#   postgresql+asyncpg://postgres.[REF]:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres
# Transaction pooler (6543) + asyncpg: add ?prepared_statement_cache_size=0
#
# Direct (OK from host / IPv4-capable networks):
#   postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://stocky:stocky_dev@localhost:5432/stock_insight

# TLS for asyncpg (cloud Postgres e.g. Supabase): auto-enabled when host is not localhost/
# host.docker.internal / compose service names postgres|db|database. Override if needed:
#   DATABASE_SSL=true   # force SSL
#   DATABASE_SSL=false  # force off (rare; local Postgres without TLS on a non-local hostname)
# If you get SSLCertVerificationError (e.g. macOS CLI Python / proxy), dev-only:
#   DATABASE_SSL_VERIFY=false
#
# Docker → cloud Postgres sometimes hits OSError [Errno 99] (bad IPv6 route). The app
# auto-rewrites the DB host to IPv4 inside Docker. Override: DATABASE_PREFER_IPV4=true|false
# (omit or "auto" for default behaviour).
# DATABASE_SSL=

# Supabase (only needed if you use the Supabase JS client / REST API directly)
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Authentication
# Generate a secure random string for production (e.g., openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI/ML Services
# Get your API keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# CORS Configuration
# Comma-separated list of allowed origins
# Development: http://localhost:3000
# Production: https://yourdomain.com
# Include both hostname forms; Next may use localhost or 127.0.0.1. Docker Compose dev also needs these.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001

# Redis (agents, cache, Celery broker). Use your cloud URL (e.g. Upstash rediss://...)
# or local: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Celery (defaults in code point at redis:6379 — override when Redis is external / localhost)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Application Environment
# Options: development, production, staging
ENVIRONMENT=development

# Sentry Error Tracking (optional — disabled if unset)
# Get from: https://sentry.io → Settings → Projects → [your project] → Client Keys (DSN)
# Note: use the BACKEND project DSN here, not the frontend one
SENTRY_DSN=

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Request/response payload logging (set false in production for sensitive data)
LOG_REQUEST_PAYLOAD=true
LOG_RESPONSE_PAYLOAD=true
LOG_PAYLOAD_MAX_LENGTH=2000
