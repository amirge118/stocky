{
  "venvPath": ".",
  "venv": "venv",
  "reportMissingTypeStubs": false,
  "executionEnvironments": [
    {
      "root": ".",
      "pythonVersion": "3.9",
      "pythonPlatform": "Darwin",
      "extraPaths": []
    }
  ],
  "include": [
    "app"
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/.*",
    "venv",
    "tests"
  ],
  "typeCheckingMode": "basic"
}
